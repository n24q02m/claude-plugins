{
  "name": "wet-mcp",
  "description": "Web search, content extraction, and media download",
  "version": "2.15.0",
  "author": {
    "name": "n24q02m",
    "url": "https://github.com/n24q02m"
  },
  "homepage": "https://github.com/n24q02m/wet-mcp",
  "mcpServers": {
    "wet": {
      "command": "uvx",
      "args": [
        "--python",
        "3.13",
        "wet-mcp"
      ],
      "env": {
        "RERANK_ENABLED": "true",
        "LOG_LEVEL": "INFO"
      }
    },
    "wet-docker": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "n24q02m/wet-mcp:latest"
      ]
    }
  },
  "skills": "./skills/"
}
