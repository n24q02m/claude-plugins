{
  "name": "wet-mcp",
  "description": "Web search, content extraction, and media download",
  "version": "2.15.0",
  "author": {
    "name": "n24q02m",
    "url": "https://github.com/n24q02m"
  },
  "homepage": "https://github.com/n24q02m/wet-mcp",
  "repository": "https://github.com/n24q02m/wet-mcp",
  "license": "MIT",
  "keywords": [
    "web-search",
    "content-extraction",
    "documentation",
    "mcp",
    "claude-code"
  ],
  "mcpServers": {
    "wet": {
      "command": "uvx",
      "args": ["--python", "3.13", "wet-mcp"],
      "env": {
        "API_KEYS": "",
        "LITELLM_PROXY_URL": "",
        "LITELLM_PROXY_KEY": "",
        "SEARXNG_URL": "",
        "EMBEDDING_MODEL": "",
        "EMBEDDING_BACKEND": "",
        "RERANK_MODEL": "",
        "RERANK_BACKEND": "",
        "RERANK_ENABLED": "true",
        "LOG_LEVEL": "INFO"
      }
    },
    "wet-pipx": {
      "command": "pipx",
      "args": ["run", "--python", "3.13", "wet-mcp"],
      "env": {
        "API_KEYS": "",
        "LITELLM_PROXY_URL": "",
        "LITELLM_PROXY_KEY": "",
        "SEARXNG_URL": "",
        "EMBEDDING_MODEL": "",
        "EMBEDDING_BACKEND": "",
        "RERANK_MODEL": "",
        "RERANK_BACKEND": "",
        "RERANK_ENABLED": "true",
        "LOG_LEVEL": "INFO"
      }
    },
    "wet-docker": {
      "command": "docker",
      "args": ["run", "--rm", "-i", "n24q02m/wet-mcp:latest"],
      "env": {
        "API_KEYS": "",
        "LITELLM_PROXY_URL": "",
        "LITELLM_PROXY_KEY": "",
        "SEARXNG_URL": "",
        "EMBEDDING_MODEL": "",
        "EMBEDDING_BACKEND": "",
        "RERANK_MODEL": "",
        "RERANK_BACKEND": "",
        "RERANK_ENABLED": "true",
        "LOG_LEVEL": "INFO"
      }
    }
  },
  "skills": "./skills/"
}
