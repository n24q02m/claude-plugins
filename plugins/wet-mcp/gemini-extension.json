{
  "name": "wet-mcp",
  "version": "2.17.0-beta.1",
  "description": "Web search, content extraction, and media download MCP server",
  "mcpServers": {
    "wet": {
      "command": "uvx",
      "args": [
        "--python",
        "3.13",
        "wet-mcp"
      ],
      "env": {
        "RERANK_ENABLED": "true",
        "LOG_LEVEL": "INFO"
      }
    }
  },
  "settings": [
    {
      "name": "API Keys",
      "description": "Cloud embedding keys (format: GOOGLE_API_KEY:xxx,COHERE_API_KEY:yyy)",
      "envVar": "API_KEYS",
      "sensitive": true
    },
    {
      "name": "GitHub Token",
      "description": "GitHub PAT for higher rate limits on docs discovery",
      "envVar": "GITHUB_TOKEN",
      "sensitive": true
    }
  ]
}
