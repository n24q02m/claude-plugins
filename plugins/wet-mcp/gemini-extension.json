{
  "name": "wet-mcp",
  "version": "2.17.0-beta.1",
  "description": "Web search, content extraction, and media download MCP server",
  "mcpServers": {
    "wet": {
      "command": "uvx",
      "args": [
        "--python",
        "3.13",
        "wet-mcp"
      ],
      "env": {
        "RERANK_ENABLED": "true",
        "LOG_LEVEL": "INFO"
      }
    }
  },
  "contextFileName": "GEMINI.md"
}
