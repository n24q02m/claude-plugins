{
  "name": "mnemo-mcp",
  "description": "Persistent AI memory — store, search, and recall knowledge across sessions",
  "version": "1.10.0",
  "author": {
    "name": "n24q02m",
    "url": "https://github.com/n24q02m"
  },
  "homepage": "https://github.com/n24q02m/mnemo-mcp",
  "mcpServers": {
    "mnemo": {
      "command": "uvx",
      "args": ["--python", "3.13", "mnemo-mcp"],
      "env": {
        "API_KEYS": "",
        "LITELLM_PROXY_URL": "",
        "LITELLM_PROXY_KEY": "",
        "DB_PATH": "",
        "RERANK_ENABLED": "true",
        "SYNC_ENABLED": "false"
      }
    },
    "mnemo-pipx": {
      "command": "pipx",
      "args": ["run", "--python", "3.13", "mnemo-mcp"],
      "env": {
        "API_KEYS": "",
        "LITELLM_PROXY_URL": "",
        "LITELLM_PROXY_KEY": "",
        "DB_PATH": "",
        "RERANK_ENABLED": "true",
        "SYNC_ENABLED": "false"
      }
    },
    "mnemo-docker": {
      "command": "docker",
      "args": ["run", "--rm", "-i", "-v", "mnemo-data:/data", "n24q02m/mnemo-mcp:latest"],
      "env": {
        "API_KEYS": "",
        "LITELLM_PROXY_URL": "",
        "LITELLM_PROXY_KEY": "",
        "DB_PATH": "/data/storage.db",
        "RERANK_ENABLED": "true",
        "SYNC_ENABLED": "false"
      }
    }
  },
  "skills": "./skills/"
}
