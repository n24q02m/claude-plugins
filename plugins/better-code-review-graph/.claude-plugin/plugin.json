{
  "name": "better-code-review-graph",
  "description": "Persistent incremental knowledge graph for token-efficient code reviews",
  "version": "3.0.0",
  "author": {
    "name": "n24q02m",
    "url": "https://github.com/n24q02m"
  },
  "homepage": "https://github.com/n24q02m/better-code-review-graph",
  "mcpServers": {
    "better-code-review-graph": {
      "command": "uvx",
      "args": ["--python", "3.13", "better-code-review-graph"],
      "env": {
        "API_KEYS": "",
        "LITELLM_PROXY_URL": "",
        "LITELLM_PROXY_KEY": ""
      }
    },
    "better-code-review-graph-pipx": {
      "command": "pipx",
      "args": ["run", "--python", "3.13", "better-code-review-graph"],
      "env": {
        "API_KEYS": "",
        "LITELLM_PROXY_URL": "",
        "LITELLM_PROXY_KEY": ""
      }
    },
    "better-code-review-graph-docker": {
      "command": "docker",
      "args": ["run", "--rm", "-i", "-v", ".:/repo:ro", "n24q02m/better-code-review-graph:latest"],
      "env": {
        "API_KEYS": "",
        "LITELLM_PROXY_URL": "",
        "LITELLM_PROXY_KEY": ""
      }
    }
  },
  "skills": "./skills/",
  "hooks": "./hooks/"
}
