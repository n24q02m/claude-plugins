{
  "name": "better-code-review-graph",
  "version": "3.3.0",
  "description": "Persistent incremental knowledge graph for token-efficient code reviews",
  "mcpServers": {
    "better-code-review-graph": {
      "command": "uvx",
      "args": [
        "--python",
        "3.13",
        "better-code-review-graph"
      ]
    }
  },
  "settings": [
    {
      "name": "API Keys",
      "description": "Cloud embedding keys (format: GOOGLE_API_KEY:xxx,COHERE_API_KEY:yyy)",
      "envVar": "API_KEYS",
      "sensitive": true
    }
  ]
}
