{
  "name": "better-email-mcp",
  "description": "Email management via IMAP/SMTP — multi-account",
  "version": "1.14.0",
  "author": {
    "name": "n24q02m",
    "url": "https://github.com/n24q02m"
  },
  "homepage": "https://github.com/n24q02m/better-email-mcp",
  "mcpServers": {
    "better-email-mcp": {
      "command": "npx",
      "args": ["-y", "@n24q02m/better-email-mcp"],
      "env": {
        "EMAIL_CREDENTIALS": "",
        "OUTLOOK_CLIENT_ID": ""
      }
    },
    "better-email-mcp-bunx": {
      "command": "bunx",
      "args": ["--bun", "@n24q02m/better-email-mcp"],
      "env": {
        "EMAIL_CREDENTIALS": "",
        "OUTLOOK_CLIENT_ID": ""
      }
    },
    "better-email-mcp-pnpx": {
      "command": "pnpx",
      "args": ["@n24q02m/better-email-mcp"],
      "env": {
        "EMAIL_CREDENTIALS": "",
        "OUTLOOK_CLIENT_ID": ""
      }
    },
    "better-email-mcp-yarn": {
      "command": "yarn",
      "args": ["dlx", "@n24q02m/better-email-mcp"],
      "env": {
        "EMAIL_CREDENTIALS": "",
        "OUTLOOK_CLIENT_ID": ""
      }
    },
    "better-email-mcp-docker": {
      "command": "docker",
      "args": ["run", "--rm", "-i", "n24q02m/better-email-mcp:latest"],
      "env": {
        "EMAIL_CREDENTIALS": "",
        "OUTLOOK_CLIENT_ID": ""
      }
    }
  },
  "skills": "./skills/"
}
