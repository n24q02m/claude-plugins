{
  "name": "better-email-mcp",
  "version": "1.15.0-beta.1",
  "description": "Email management via IMAP/SMTP — multi-account",
  "mcpServers": {
    "better-email-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@n24q02m/better-email-mcp"
      ]
    }
  },
  "settings": [
    {
      "name": "Email Credentials",
      "description": "Email credentials (format: user@gmail.com:app-password)",
      "envVar": "EMAIL_CREDENTIALS",
      "sensitive": true
    }
  ]
}
