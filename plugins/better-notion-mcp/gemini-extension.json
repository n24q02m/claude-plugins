{
  "name": "better-notion-mcp",
  "version": "2.22.0",
  "description": "Comprehensive Notion API integration — 9 composite tools, ~95% coverage",
  "mcpServers": {
    "better-notion-mcp": {
      "command": "npx",
      "args": ["-y", "@n24q02m/better-notion-mcp"]
    }
  },
  "settings": [
    {
      "name": "Notion Token",
      "description": "Notion integration token from notion.so/my-integrations",
      "envVar": "NOTION_TOKEN",
      "sensitive": true
    }
  ]
}
