{
  "name": "better-notion-mcp",
  "description": "Comprehensive Notion API integration — 9 composite tools, ~95% coverage",
  "version": "2.20.0",
  "author": {
    "name": "n24q02m",
    "url": "https://github.com/n24q02m"
  },
  "homepage": "https://github.com/n24q02m/better-notion-mcp",
  "mcpServers": {
    "better-notion-mcp-http": {
      "type": "http",
      "url": "https://better-notion-mcp.n24q02m.com/mcp"
    },
    "better-notion-mcp": {
      "command": "npx",
      "args": ["-y", "@n24q02m/better-notion-mcp"],
      "env": {
        "NOTION_TOKEN": ""
      }
    },
    "better-notion-mcp-bunx": {
      "command": "bunx",
      "args": ["--bun", "@n24q02m/better-notion-mcp"],
      "env": {
        "NOTION_TOKEN": ""
      }
    },
    "better-notion-mcp-pnpx": {
      "command": "pnpx",
      "args": ["@n24q02m/better-notion-mcp"],
      "env": {
        "NOTION_TOKEN": ""
      }
    },
    "better-notion-mcp-yarn": {
      "command": "yarn",
      "args": ["dlx", "@n24q02m/better-notion-mcp"],
      "env": {
        "NOTION_TOKEN": ""
      }
    },
    "better-notion-mcp-docker": {
      "command": "docker",
      "args": ["run", "--rm", "-i", "-p", "8080:8080", "n24q02m/better-notion-mcp:latest"],
      "env": {
        "NOTION_TOKEN": "",
        "TRANSPORT_MODE": "http",
        "PORT": "8080"
      }
    }
  },
  "skills": "./skills/"
}
